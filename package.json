{
  "name": "vrchat-api-typescript",
  "version": "1.1.0",
  "description": "TypeScript SDK and type definitions generated from the VRChat API OpenAPI specification.",
  "author": {
    "name": "Ferdinand Lim"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TechTeem/vrchat-api-typescript.git"
  },
  "homepage": "https://github.com/TechTeem/vrchat-api-typescript",
  "bugs": {
    "url": "https://github.com/TechTeem/vrchat-api-typescript/issues"
  },
  "keywords": [
    "vrchat",
    "api",
    "typescript",
    "sdk",
    "openapi"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "openapi.json",
    "README.md",
    "README.javascript.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf dist src/generated openapi.json",
    "spec:update": "node ./scripts/update-spec.mjs",
    "generate": "npm run spec:update && openapi-ts",
    "build": "tsup",
    "example:session": "npm run build && node ./examples/session-login.mjs",
    "example:websocket": "npm run build && node ./examples/websocket-notifications.mjs",
    "prepack": "npm run generate && npm run build"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.88.0",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
